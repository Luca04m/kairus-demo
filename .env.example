# Kairus OS — Variaveis de ambiente
# Copie este arquivo para .env e preencha os valores necessarios.

# Supabase (auth e banco de dados)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenRouter (AI provider — opcional, para chat com agentes)
OPENROUTER_API_KEY=

# Bling ERP (integracao de estoque — opcional)
BLING_API_KEY=

# Vault de dados do cliente (caminho local — opcional)
MRLION_VAULT_PATH=
